<?xml version="1.0" encoding="UTF-8"?>
<!--
  installer.wxs — WiX v4 source for the Obliview Windows installer
  ─────────────────────────────────────────────────────────────────
  Requirements:
    dotnet tool install --global wix
    wix extension add WixToolset.UI.wixext        (optional — for UI)

  Build (from desktop-app/ directory):
    wix build installer.wxs -o dist\ObliviewSetup.msi

  Or use build-windows.ps1 which handles the full pipeline.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="Obliview"
      Manufacturer="BinaryHearts"
      Version="DESKTOP_VERSION_PLACEHOLDER"
      UpgradeCode="F8A2C3D4-E5B6-4789-9ABC-DEF012345678"
      Compressed="yes">

    <!--
      MajorUpgrade: silently removes any older version before installing.
      If the user has a NEWER version, show a friendly error and abort.
    -->
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of Obliview is already installed. Uninstall it first." />

    <!-- Install to %ProgramFiles%\Obliview\ -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="Obliview">

        <!-- Main component: the executable + Start Menu shortcut -->
        <Component Id="MainExecutable">
          <File Source="dist\Obliview.exe" KeyPath="yes">
            <Shortcut
                Id="StartMenuShortcut"
                Directory="ProgramMenuFolder"
                Name="Obliview"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon"
                Advertise="yes" />
          </File>
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut (optional feature, pre-selected) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent">
        <Shortcut
            Id="DesktopShortcut"
            Name="Obliview"
            WorkingDirectory="INSTALLFOLDER"
            Target="[INSTALLFOLDER]Obliview.exe"
            Icon="AppIcon" />
        <RegistryValue
            Root="HKCU"
            Key="Software\BinaryHearts\Obliview"
            Name="DesktopShortcut"
            Value="1"
            Type="integer"
            KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Start Menu folder (needed as shortcut target directory) -->
    <StandardDirectory Id="ProgramMenuFolder" />

    <!-- Feature tree -->
    <Feature Id="Main" Title="Obliview" Level="1" Absent="disallow">
      <ComponentRef Id="MainExecutable" />
    </Feature>

    <Feature Id="DesktopIcon" Title="Desktop shortcut" Level="1" Absent="allow">
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>

    <!-- App icon (title bar, Add/Remove Programs) -->
    <Icon Id="AppIcon" SourceFile="logo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK"    Value="https://obliview.app" />

  </Package>
</Wix>
