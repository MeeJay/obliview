# ── Image version (tag Docker Hub, ex: latest, 1.0.0) ──
OBLIVIEW_VERSION=latest

# ── Database ──
# If using the built-in postgres container (docker-compose.yml):
DB_PASSWORD=changeme

# If using an external PostgreSQL (docker-compose.external-db.yml):
# DATABASE_URL=postgres://obliview:yourpassword@your-db-host:5432/obliview

# ── Server ──
PORT=3001
NODE_ENV=production
SESSION_SECRET=change-this-to-a-random-secret

# ── Client origin (for CORS — set to your actual URL) ──
CLIENT_ORIGIN=http://localhost
# LISTEN_PORT=3000

# ── App name (used as prefix in notification messages) ──
APP_NAME=Obliview

# ── Default admin (created on first run) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Custom directory (scripts, SSH keys — persists across updates) ──
# Mounted at /custom inside the server container.
# Default: ./custom (next to your docker-compose.yml)
# Unraid example: CUSTOM_DIR=/mnt/user/appdata/obliview/custom
# CUSTOM_DIR=./custom
